{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // tsup's DTS bundler (rollup-plugin-dts) sets `baseUrl` internally, which TS 6
    // flags as deprecated (TS5101); our own configs are baseUrl-free. Tolerate it
    // for the 6.0 grace period — drop once the bundler stops emitting baseUrl.
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["dist", "**/*.test.ts", "**/*.test.tsx"]
}
